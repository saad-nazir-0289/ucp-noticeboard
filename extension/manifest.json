{
  "manifest_version": 3,
  "name": "UCP NoticeBoard",
  "version": "1.0.0",
  "description": "Injects a live NoticeBoard into the UCP Student Portal dashboard.",
  "permissions": [],
  "host_permissions": [
    "https://horizon.ucp.edu.pk/*",
    "https://ucp-noticeboard-production.up.railway.app/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://horizon.ucp.edu.pk/student/dashboard*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "128": "icon128.png"
  }
}